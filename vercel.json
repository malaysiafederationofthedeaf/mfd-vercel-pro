{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    { "src": "/api/bims", "dest": "/api/bims.js" },
    { "src": "/api/category-groups", "dest": "/api/category-groups.js" },
    { "src": "/api/debug", "dest": "/api/debug.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
